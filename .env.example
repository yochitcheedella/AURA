# AURA — Environment Variables Template
# ============================================================
# This file is SAFE TO COMMIT — it contains only placeholders.
# 
# To set up your local environment:
#   1. Copy this file:  copy .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env — it is already in .gitignore
# ============================================================

# ===========================================================================
# CLERK (Required — Auth)
# Get from: https://dashboard.clerk.com → API Keys
# ===========================================================================
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_FRONTEND_API_URL=your-clerk-subdomain.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ===========================================================================
# NEON (Required — Database)
# Get from: https://console.neon.tech → Your Project → Connection Details
# Use the POOLED connection string for serverless (recommended)
# ===========================================================================
DATABASE_URL=postgresql://your_user:your_password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ===========================================================================
# CLOUDFLARE R2 (Optional — Voice recording / file storage)
# R2 bucket binding is configured via wrangler.toml (env.R2_BUCKET).
# Only add the URL below if you enable public access on the bucket.
# ===========================================================================
VITE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ===========================================================================
# APP
# ===========================================================================
VITE_APP_NAME=AURA
VITE_APP_VERSION=2.0.0
VITE_APP_ENV=development
